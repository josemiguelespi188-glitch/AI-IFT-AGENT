# =============================================================
# Axiskey IR Agent — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Zendesk ---
ZENDESK_SUBDOMAIN=your_subdomain          # e.g. industryfintech
ZENDESK_EMAIL=support@industryfintech.com
ZENDESK_API_TOKEN=your_zendesk_api_token

# --- Email (IMAP inbound / SMTP outbound) ---
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=support@industryfintech.com
EMAIL_PASSWORD=your_email_app_password

# --- Portal / Tribexa API ---
TRIBEXA_API_URL=https://api.tribexa.com
TRIBEXA_API_KEY=your_tribexa_api_key

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Escalation ---
ESCALATION_EMAIL=ir-team@industryfintech.com
